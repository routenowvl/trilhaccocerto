Filiais Especiais = 
SWITCH(
    TRUE(),
    [PLANTA] IN {"CASTROLANDA - CASTRO", "SEARA - CASTRO"}, 1,
    [PLANTA] IN {"CCPR - UBERLANDIA", "SCALA - SACRAMENTO", "SCALA NUTRICAO - SACRAMENTO", "T2 - UBERLANDIA"}, 2,
    [PLANTA] IN {"CATUPIRY - DOVERLANDIA", "CATUPIRY - SANTA VITORIA", "PIRACANJUBA - SANTA VITORIA"}, 3,
    [PLANTA] IN {"DANONE - BOA ESPERANÇA", "DANONE - POÇOS DE CALDAS"}, 4,
    [PLANTA] IN {"DPA - GARANHUNS", "LACTALIS - BOM CONSELHO"}, 5,
    [PLANTA] IN {"CCPR - POMPEU", "CCPR - PARA DE MINAS", "PIRACANJUBA - CURVELO"}, 6,
    [PLANTA] IN {"COTRIROSA - GIRUA", "ITALAC - CRISSIUMAL"}, 7,
    [PLANTA] IN {"SEARA - TRINDADE DO SUL", "SEARA - SAO MIGUEL DO OESTE"}, 8,
    [PLANTA] IN {"LACTALIS - BARRA MANSA", "PIRACANJUBA - TRES RIOS"}, 9,
	[PLANTA] IN {"CCPR - UNAI", "PIRACANJUBA - UNAI"}, 10,
    BLANK()
)
